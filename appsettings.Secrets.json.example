{
  "_comment": "Copy this file to 'appsettings.Secrets.json' (which is gitignored) and set real values. PassHash is a PBKDF2 'salt:hash' pair from Auth.HashPassword(\"yourPassword\"). In production prefer the MASTER_USER / MASTER_PASS_HASH environment variables instead. The Notifications block below overrides the disabled defaults in appsettings.json - keep webhook URLs, HMAC keys and SMTP credentials here (out of source control), not in appsettings.json.",
  "Auth": {
    "User": "admin",
    "PassHash": "<base64Salt>:<base64Hash>"
  },
  "Notifications": {
    "Webhook": {
      "Enabled": true,
      "MinSeverity": "High",
      "Flavor": "Slack",
      "Url": "https://hooks.slack.com/services/T000/B000/XXXXXXXXXXXX",
      "HmacSecret": "optional-shared-secret-for-generic-webhooks"
    },
    "Syslog": {
      "Enabled": true,
      "MinSeverity": "Medium",
      "Host": "siem.example.local",
      "Port": 514,
      "Protocol": "Udp"
    },
    "Email": {
      "Enabled": false,
      "MinSeverity": "Critical",
      "Host": "smtp.example.com",
      "Port": 587,
      "UseStartTls": true,
      "Username": "alerts@example.com",
      "Password": "app-password",
      "From": "alerts@example.com",
      "To": "soc@example.com"
    }
  }
}
